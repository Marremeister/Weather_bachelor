# =============================================================================
# Sea Breeze Analog — Environment Variables
# =============================================================================
# Copy to .env and fill in values.
# Lines marked (Railway) are auto-injected or set in the Railway dashboard.

# --- Database ---
# Local dev (docker compose): uses the default below, no changes needed.
# Railway: auto-injects DATABASE_URL as postgresql://... — the app auto-converts
#          it to the postgresql+psycopg:// dialect required by psycopg.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/seabreeze
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seabreeze

# --- App ---
# "development" or "production"
APP_ENV=development

# --- CORS ---
# Comma-separated list of allowed origins.
# In production (single-container), CORS is not needed since frontend is served
# from the same origin. Set to your domain if you have external API consumers.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# --- CDS API (Copernicus Climate Data Store) ---
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=

# --- Weather cache ---
# Local dev: ../data/cache (bind-mounted volume)
# Railway: /tmp/cache (ephemeral; Postgres is the durable cache)
WEATHER_CACHE_DIR=../data/cache

# --- Location defaults ---
DEFAULT_LATITUDE=33.708965
DEFAULT_LONGITUDE=-118.268343
DEFAULT_TIMEZONE=America/Los_Angeles

# --- Railway-specific (set in dashboard, not in .env) ---
# PORT — auto-injected by Railway, used by uvicorn
# RAILWAY_ENVIRONMENT — set automatically
